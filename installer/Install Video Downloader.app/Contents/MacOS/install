#!/bin/bash
# Video Downloader — One-time installer
# Runs in Terminal so the user can see progress and approve Homebrew install.

SCRIPT_DIR="$(cd "$(dirname "$0")/../../.." && pwd)"

osascript -e "
tell application \"Terminal\"
    activate
    do script \"bash '$SCRIPT_DIR/install.command'; echo ''; echo 'You can close this window now.'; exit\"
end tell
"
